{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=DevinyDB;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyForDevinyApp12345678901234567890",
    "Issuer": "DevinyApp",
    "Audience": "DevinyApp"
  },
  "ClientAppUrl": "http://localhost:3000",
  "FileStorage": {
    "BaseUrl": "http://localhost:5000",
    "BasePath": "uploads",
    "MaxImageSizeBytes": 10485760,
    "MaxVideoSizeBytes": 104857600,
    "AllowedImageExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp"],
    "AllowedVideoExtensions": [".mp4", ".mov", ".webm"],
    "AllowedImageContentTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"],
    "AllowedVideoContentTypes": ["video/mp4", "video/quicktime", "video/webm"]
  }
}
